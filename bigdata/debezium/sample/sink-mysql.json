{
    "name": "debezium-mysql-dvdrental",
    "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",

    "topics.regex": "dvdrental\\.public\\..*",
    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",

    "connection.url": "jdbc:mysql://mysql:3306/dvdrental",
    "connection.username": "root",
    "connection.password": "SuperSecr3t",
    "collection.name.format": "${source.table}",
    "hibernate.connection.nullDatabaseMeansCurrent": "true",

    "primary.key.mode": "record_key",
    "schema.evolution": "basic",
    "insert.mode": "upsert",
    "delete.enabled": "false",
    "truncate.enabled": "false",

    "use.reduction.buffer": "true",
    "use.time.zone": "UTC"
}
